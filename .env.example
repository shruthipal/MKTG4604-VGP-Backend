# Copy to .env and fill in real values before running

# ── Shared ────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-long-random-secret
DATABASE_URL=sqlite+aiosqlite:///./vgp.db
# For PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/vgp

# ── Inventory Service ─────────────────────────────────────────────────────────
# Path where ChromaDB persists its index files
CHROMA_PATH=./chroma_db
